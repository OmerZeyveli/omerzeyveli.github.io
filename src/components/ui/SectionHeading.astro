---
// Purpose: Render a section heading with overline and link.
// Scope: UI component for section headers.
// Audience: Index and listing pages.
interface Props {
  overline: string;
  title: string;
  href: string;
  linkText: string;
}

const { overline, title, href, linkText } = Astro.props;
---

<div
  class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between sm:gap-4"
>
  <div>
    <p class="text-sm uppercase tracking-[0.2em] text-zinc-400">{overline}</p>
    <h2 class="text-xl font-semibold tracking-tight sm:text-2xl">{title}</h2>
  </div>
  <a
    href={href}
    class="text-sm text-zinc-400 transition-colors hover:text-zinc-200"
  >
    {linkText} &rarr;
  </a>
</div>
