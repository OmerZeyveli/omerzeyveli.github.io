---
import { Image } from "astro:assets";

interface Props {
  src: any;
  alt: string;
  caption?: string;
}

const { src, alt, caption } = Astro.props;
---

<figure class="my-8 space-y-3">
  <Image
    src={src}
    alt={alt}
    class="w-full rounded-2xl border border-zinc-800 sm:rounded-3xl"
    widths={[800, 1200, 1600]}
    sizes="(max-width: 768px) 100vw, 768px"
  />
  {
    caption && (
      <figcaption class="text-center text-sm text-zinc-500">
        {caption}
      </figcaption>
    )
  }
</figure>
