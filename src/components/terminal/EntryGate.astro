<div
  id="entry-gate"
  data-entry-gate
  hidden
  class="fixed inset-0 z-50 flex items-center justify-center bg-zinc-950/90 px-4 backdrop-blur-sm"
  role="dialog"
  aria-modal="true"
  aria-labelledby="entry-gate-title"
>
  <div
    class="w-full max-w-md rounded-2xl border border-zinc-800 bg-zinc-900 p-6 shadow-2xl"
  >
    <p
      id="entry-gate-title"
      class="text-xs uppercase tracking-[0.2em] text-zinc-400"
    >
      Visitor check
    </p>
    <h2 class="mt-2 text-2xl font-semibold tracking-tight text-zinc-100">
      Are you a human?
    </h2>
    <p class="mt-3 text-sm leading-6 text-zinc-400">
      Quick gut check before you come in.
    </p>

    <div class="mt-6 flex flex-col gap-3">
      <button
        type="button"
        data-entry-gate-human
        class="rounded-2xl border border-emerald-500/40 bg-emerald-500/10 px-4 py-2 text-sm font-medium text-emerald-300 transition-colors hover:bg-emerald-500/20 focus-visible:ring-2 focus-visible:ring-emerald-400 focus-visible:ring-offset-2 focus-visible:ring-offset-zinc-950"
      >
        Yes, I am a human
      </button>
      <button
        type="button"
        data-entry-gate-programmer
        class="rounded-2xl border border-zinc-700 bg-zinc-800 px-4 py-2 text-sm font-medium text-zinc-100 transition-colors hover:bg-zinc-700 focus-visible:ring-2 focus-visible:ring-zinc-400 focus-visible:ring-offset-2 focus-visible:ring-offset-zinc-950"
      >
        No, I am a programmer
      </button>
    </div>
  </div>
</div>

<script>
  const STORAGE_KEY = "riive:entry-mode";

  function initGate() {
    const root = document.querySelector<HTMLElement>("[data-entry-gate]");
    if (!root || root.dataset.bound) return;
    root.dataset.bound = "true";

    let stored: string | null = null;
    try {
      stored = window.localStorage.getItem(STORAGE_KEY);
    } catch {
      stored = null;
    }

    if (stored !== "human" && stored !== "programmer") {
      root.hidden = false;
    }

    const close = (mode: "human" | "programmer") => {
      try {
        window.localStorage.setItem(STORAGE_KEY, mode);
      } catch {
        // Storage unavailable — proceed without persistence.
      }
      root.hidden = true;
      if (mode === "programmer") {
        window.location.assign("/terminal");
      }
    };

    root
      .querySelector("[data-entry-gate-human]")
      ?.addEventListener("click", () => close("human"));
    root
      .querySelector("[data-entry-gate-programmer]")
      ?.addEventListener("click", () => close("programmer"));
  }

  initGate();
  // Rebind when the client router swaps the homepage back in.
  document.addEventListener("astro:page-load", initGate);
</script>
