---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ui/ProjectCard.astro";
import WritingCard from "../components/ui/WritingCard.astro";
import ReviewCard from "../components/ui/ReviewCard.astro";
import SectionHeading from "../components/ui/SectionHeading.astro";
import { siteConfig } from "../config/site";
import {
  getFeaturedProjects,
  getLatestWriting,
  getLatestReviews,
} from "../lib/content";

const featuredProjects = (await getFeaturedProjects()).slice(0, 3);
const latestWriting = await getLatestWriting(3);
const latestReviews = await getLatestReviews(3);
---

<BaseLayout
  title="Home"
  description="Developer-first personal site with project case studies, writing, and reviews across games, media, and tech."
>
  <section class="space-y-6 border-b border-zinc-800 pb-12">
    <p class="text-sm uppercase tracking-[0.2em] text-zinc-400">
      {siteConfig.name}
    </p>

    <h1
      class="max-w-4xl text-3xl font-semibold tracking-tight sm:text-4xl md:text-5xl lg:text-6xl"
    >
      Building projects, documenting process, and writing thoughtful reviews.
    </h1>

    <p class="max-w-2xl text-base leading-7 text-zinc-300">
      A developer-first personal site focused on project case studies, writing,
      and reviews across games, media, and tech.
    </p>

    <div class="flex flex-wrap gap-3">
      <a
        href="/projects"
        class="rounded-2xl border border-zinc-800 px-4 py-2 text-sm transition-colors hover:bg-zinc-900 focus-visible:ring-2 focus-visible:ring-zinc-400 focus-visible:ring-offset-2 focus-visible:ring-offset-zinc-950 sm:text-base"
      >
        View Projects
      </a>
      <a
        href="/reviews"
        class="rounded-2xl border border-zinc-800 px-4 py-2 text-sm transition-colors hover:bg-zinc-900 focus-visible:ring-2 focus-visible:ring-zinc-400 focus-visible:ring-offset-2 focus-visible:ring-offset-zinc-950 sm:text-base"
      >
        Read Reviews
      </a>
      <a
        href="/writing"
        class="rounded-2xl border border-zinc-800 px-4 py-2 text-sm transition-colors hover:bg-zinc-900 focus-visible:ring-2 focus-visible:ring-zinc-400 focus-visible:ring-offset-2 focus-visible:ring-offset-zinc-950 sm:text-base"
      >
        Explore Writing
      </a>
    </div>
  </section>

  {
    featuredProjects.length > 0 && (
      <section class="space-y-6 py-12">
        <SectionHeading
          overline="Featured"
          title="Featured Projects"
          href="/projects"
          linkText="All projects"
        />

        <div class="grid gap-6 sm:grid-cols-2 md:grid-cols-3">
          {featuredProjects.map((project) => (
            <ProjectCard
              href={`/projects/${project.id}/`}
              cover={project.data.cover}
              coverAlt={project.data.coverAlt}
              title={project.data.title}
              summary={project.data.summary}
              category={project.data.category}
              year={project.data.year}
              stack={project.data.stack}
              headingLevel="h3"
              sizes="(max-width: 768px) 100vw, 33vw"
            />
          ))}
        </div>
      </section>
    )
  }

  {
    (latestWriting.length > 0 || latestReviews.length > 0) && (
      <section class="grid gap-8 border-t border-zinc-800 py-12 md:grid-cols-2">
        {latestWriting.length > 0 && (
          <div class="space-y-5">
            <SectionHeading
              overline="Writing"
              title="Latest Writing"
              href="/writing"
              linkText="All writing"
            />

            <div class="space-y-4">
              {latestWriting.map((post) => (
                <WritingCard
                  href={`/writing/${post.id}/`}
                  cover={post.data.cover}
                  coverAlt={post.data.coverAlt}
                  title={post.data.title}
                  description={post.data.description}
                  category={post.data.category}
                  pubDate={post.data.pubDate}
                  headingLevel="h3"
                />
              ))}
            </div>
          </div>
        )}

        {latestReviews.length > 0 && (
          <div class="space-y-5">
            <SectionHeading
              overline="Reviews"
              title="Latest Reviews"
              href="/reviews"
              linkText="All reviews"
            />

            <div class="space-y-4">
              {latestReviews.map((review) => (
                <ReviewCard
                  href={`/reviews/${review.id}/`}
                  cover={review.data.cover}
                  coverAlt={review.data.coverAlt}
                  title={review.data.title}
                  description={review.data.description}
                  type={review.data.type}
                  score={review.data.score}
                  headingLevel="h3"
                />
              ))}
            </div>
          </div>
        )}
      </section>
    )
  }
</BaseLayout>
