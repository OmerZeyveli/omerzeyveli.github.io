---
// Purpose: Render the in-browser shell that browses content collections as files.
// Scope: Client-only route reached from the "programmer" entry gate or footer link.
// Audience: Visitors who prefer a CLI over a graphical landing page.
import TerminalLayout from "../layouts/TerminalLayout.astro";
import { getProjects, getWritingPosts, getReviews } from "../lib/content";
import { siteConfig } from "../config/site";

type Entry = { slug: string; title: string };

const toEntries = (
  items: Array<{ id: string; data: { title: string } }>,
): Entry[] => items.map((item) => ({ slug: item.id, title: item.data.title }));

const fs = {
  projects: toEntries(await getProjects()),
  writing: toEntries(await getWritingPosts()),
  reviews: toEntries(await getReviews()),
};

const author = siteConfig.name;
---

<TerminalLayout>
  <main
    id="term"
    class="fixed inset-0 overflow-y-auto bg-black font-mono text-sm leading-6 text-emerald-300"
  >
    <div class="px-4 py-4 sm:px-6">
      <div
        id="term-output"
        class="whitespace-pre-wrap break-words"
        aria-live="polite"
        role="log"
      >
      </div>
      <form id="term-form" class="flex items-baseline gap-2" autocomplete="off">
        <span id="term-prefix" class="shrink-0 text-emerald-400 select-none"
          >visitor@riive:/$</span
        >
        <span id="term-line" class="relative inline-block min-w-[1ch]">
          <span id="term-shadow" class="whitespace-pre text-emerald-100"></span>
          <input
            id="term-input"
            type="text"
            class="absolute inset-0 h-full w-full appearance-none border-0 bg-transparent p-0 text-transparent caret-transparent outline-none"
            autocomplete="off"
            autocapitalize="off"
            autocorrect="off"
            spellcheck="false"
            aria-label="Terminal input"
          />
        </span>
      </form>
    </div>
  </main>

  <style is:global>
    /* Block cursor: a ::after on the shadow span. It trails the text with no
       whitespace gap and — crucially — keeps a stable baseline even when the
       input is empty. Anchored to the text baseline (with a small dip below it
       for the descender area) so it sits on the text like a character cell,
       independent of line-height. Blink is driven from JS (see script) so it
       survives the global reduced-motion rule that disables CSS animations. */
    #term-shadow::after {
      content: "";
      display: inline-block;
      width: 0.9ch;
      height: 1em;
      margin-left: 1px;
      margin-bottom: -0.15em;
      vertical-align: baseline;
      background-color: #6ee7b7;
      opacity: var(--term-cursor-opacity, 1);
    }
    /* Override the global focus-visible ring; the cursor is the focus cue. */
    #term-input:focus,
    #term-input:focus-visible {
      outline: none;
      border-radius: 0;
    }
  </style>

  <script is:inline define:vars={{ fs, author }}>
    const STORAGE_KEY = "riive:entry-mode";
    const collections = ["projects", "writing", "reviews"];
    const NIM_START_HEAPS = [1, 3, 5, 7];
    const NIM_PC_DELAY_MS = 1000;
    const NIM_STATES = {
      SELECTING_STARTER: "selecting-starter",
      PLAYER_TURN: "player-turn",
      PC_THINKING: "pc-thinking",
      ENDED: "ended",
    };

    const term = document.getElementById("term");
    const output = document.getElementById("term-output");
    const form = document.getElementById("term-form");
    const input = document.getElementById("term-input");
    const prefix = document.getElementById("term-prefix");
    const shadow = document.getElementById("term-shadow");
    if (!term || !output || !form || !input || !prefix || !shadow) {
      throw new Error("terminal: missing DOM");
    }

    let cwd = "/";
    let nimGame = null;
    const history = [];
    let historyIndex = -1;
    let draft = "";

    const promptLabel = () =>
      nimGame ? "visitor@riive:nim$" : `visitor@riive:${cwd}$`;

    const renderPrefix = () => {
      prefix.textContent = promptLabel();
    };

    const print = (text = "", className = "") => {
      const line = document.createElement("div");
      if (className) line.className = className;
      line.textContent = text;
      output.appendChild(line);
    };

    const printHTML = (html, className = "") => {
      const line = document.createElement("div");
      if (className) line.className = className;
      line.innerHTML = html;
      output.appendChild(line);
    };

    const scrollToBottom = () => {
      term.scrollTop = term.scrollHeight;
    };

    // Mirror the (transparent) input into the visible shadow span so the
    // block cursor — a ::after on the shadow — always trails the typed text.
    const renderInput = () => {
      shadow.textContent = input.value;
    };

    const escapeHTML = (value) =>
      String(value).replace(
        /[&<>"']/g,
        (ch) =>
          ({
            "&": "&amp;",
            "<": "&lt;",
            ">": "&gt;",
            '"': "&quot;",
            "'": "&#39;",
          })[ch] ?? ch,
      );

    const banner = () => {
      print(`${author} // terminal`, "text-emerald-400");
      print(
        "Type `help` to see commands. Type `exit` to leave.",
        "text-zinc-500",
      );
      print("");
    };

    const resolvePath = (raw) => {
      if (!raw || raw === "~") return "/";
      let parts;
      if (raw.startsWith("/")) {
        parts = raw.split("/").filter(Boolean);
      } else {
        const base = cwd === "/" ? [] : cwd.split("/").filter(Boolean);
        parts = base.concat(raw.split("/").filter(Boolean));
      }
      const stack = [];
      for (const part of parts) {
        if (part === "." || part === "") continue;
        if (part === "..") {
          stack.pop();
          continue;
        }
        stack.push(part);
      }
      return "/" + stack.join("/");
    };

    const listAt = (path) => {
      if (path === "/") {
        return collections.map((name) => ({ name, kind: "dir" }));
      }
      const segments = path.split("/").filter(Boolean);
      if (segments.length === 1 && collections.includes(segments[0])) {
        return fs[segments[0]].map((entry) => ({
          name: entry.slug,
          kind: "file",
          title: entry.title,
        }));
      }
      return null;
    };

    const findEntry = (collection, slug) =>
      fs[collection]?.find((entry) => entry.slug === slug) ?? null;

    const createNimGame = () => ({
      heaps: [...NIM_START_HEAPS],
      state: NIM_STATES.SELECTING_STARTER,
      starter: null,
      starterSelection: "user",
      pcHasMoved: false,
      pcTimeoutId: null,
      starterMenuLine: null,
    });

    const nimTotal = (heaps) => heaps.reduce((total, heap) => total + heap, 0);

    const nimLegalMoves = (heaps) => {
      const moves = [];
      for (const [index, heap] of heaps.entries()) {
        for (let count = 1; count <= heap; count += 1) {
          const next = [...heaps];
          next[index] -= count;
          moves.push({ heap: index + 1, count, next });
        }
      }
      return moves;
    };

    const nimStateKey = (heaps) => heaps.join(",");

    const isNimWinningState = (heaps, memo = new Map()) => {
      const key = nimStateKey(heaps);
      if (memo.has(key)) return memo.get(key);
      const moves = nimLegalMoves(heaps);
      if (moves.length === 0) {
        memo.set(key, true);
        return true;
      }
      const winning = moves.some((move) => !isNimWinningState(move.next, memo));
      memo.set(key, winning);
      return winning;
    };

    const chooseNimBotMove = (heaps) => {
      const memo = new Map();
      return (
        nimLegalMoves(heaps)
          .map((move) => ({
            ...move,
            isWinningMove: !isNimWinningState(move.next, memo),
            playerWinningReplies: nimLegalMoves(move.next).filter(
              (reply) => !isNimWinningState(reply.next, memo),
            ).length,
            remaining: nimTotal(move.next),
          }))
          .sort(
            (a, b) =>
              Number(b.isWinningMove) - Number(a.isWinningMove) ||
              a.playerWinningReplies - b.playerWinningReplies ||
              b.remaining - a.remaining ||
              a.heap - b.heap ||
              a.count - b.count,
          )[0] ?? null
      );
    };

    const chooseRandomNimMove = (heaps) => {
      const moves = nimLegalMoves(heaps);
      return moves[Math.floor(Math.random() * moves.length)] ?? null;
    };

    const chooseNimComputerMove = () => {
      if (!nimGame) return null;
      if (nimGame.starter === "pc" && !nimGame.pcHasMoved) {
        return chooseRandomNimMove(nimGame.heaps);
      }
      return chooseNimBotMove(nimGame.heaps);
    };

    const formatNimStones = (count) => (count === 0 ? "-" : "#".repeat(count));

    const renderNimStarterMenu = () => {
      if (!nimGame) return "";
      return [
        "choose who starts:",
        `${nimGame.starterSelection === "user" ? ">" : " "} user`,
        `${nimGame.starterSelection === "pc" ? ">" : " "} pc`,
      ].join("\n");
    };

    const printNimStarterHelp = () => {
      if (!nimGame) return;
      if (nimGame.starterMenuLine?.isConnected) {
        nimGame.starterMenuLine.textContent = renderNimStarterMenu();
        return;
      }
      const line = document.createElement("div");
      line.textContent = renderNimStarterMenu();
      output.appendChild(line);
      nimGame.starterMenuLine = line;
    };

    const isSelectingNimStarter = () =>
      nimGame?.state === NIM_STATES.SELECTING_STARTER;

    const toggleNimStarterSelection = () => {
      if (!isSelectingNimStarter()) return false;
      nimGame.starterSelection =
        nimGame.starterSelection === "user" ? "pc" : "user";
      printNimStarterHelp();
      scrollToBottom();
      return true;
    };

    const normalizeNimStarter = (value) => {
      const starter = value.toLowerCase();
      if (starter === "user" || starter === "me") return "user";
      if (starter === "pc" || starter === "computer" || starter === "bot") {
        return "pc";
      }
      return null;
    };

    const printNimBoard = () => {
      if (!nimGame) return;
      print("board:", "text-emerald-400");
      for (const [index, heap] of nimGame.heaps.entries()) {
        print(`  ${index + 1}: ${formatNimStones(heap)} (${heap})`);
      }
    };

    const printNimHelp = () => {
      print("nim commands:", "text-emerald-400");
      print("  user | pc       choose who starts");
      print("  <heap> <count>  take stones, e.g. 1 2");
      print("  restart         reset the board");
      print("  quit            return to the shell");
      print("  exit            leave the terminal");
    };

    const clearNimComputerTimeout = (game = nimGame) => {
      if (!game?.pcTimeoutId) return;
      window.clearTimeout(game.pcTimeoutId);
      game.pcTimeoutId = null;
    };

    const leaveNim = (message) => {
      clearNimComputerTimeout();
      nimGame = null;
      if (message) print(message);
    };

    const finishNim = (message, className) => {
      if (nimGame) {
        clearNimComputerTimeout();
        nimGame.state = NIM_STATES.ENDED;
      }
      print(message, className);
      nimGame = null;
    };

    const playNimComputerTurn = () => {
      if (!nimGame) return;
      clearNimComputerTimeout();
      const computerMove = chooseNimComputerMove();
      if (!computerMove) {
        finishNim("pc wins.", "text-rose-400");
        return;
      }
      nimGame.heaps = computerMove.next;
      nimGame.pcHasMoved = true;
      print(`pc takes ${computerMove.count} from heap ${computerMove.heap}.`);
      if (nimTotal(nimGame.heaps) === 0) {
        finishNim("you win.", "text-emerald-400");
        return;
      }
      nimGame.state = NIM_STATES.PLAYER_TURN;
      printNimBoard();
    };

    const scheduleNimComputerTurn = () => {
      if (!nimGame) return;
      clearNimComputerTimeout();
      const game = nimGame;
      game.state = NIM_STATES.PC_THINKING;
      game.pcTimeoutId = window.setTimeout(() => {
        if (nimGame !== game || game.state !== NIM_STATES.PC_THINKING) return;
        game.pcTimeoutId = null;
        playNimComputerTurn();
        renderPrefix();
        scrollToBottom();
      }, NIM_PC_DELAY_MS);
    };

    const chooseNimStarter = (starter) => {
      if (!nimGame) return false;
      const normalizedStarter = normalizeNimStarter(starter);
      if (!normalizedStarter) return false;
      nimGame.starter = normalizedStarter;
      if (normalizedStarter === "user") {
        nimGame.state = NIM_STATES.PLAYER_TURN;
        print("you start.");
        printNimBoard();
      } else {
        nimGame.state = NIM_STATES.PC_THINKING;
        print("pc starts.");
        playNimComputerTurn();
      }
      return true;
    };

    const startNim = (args = []) => {
      clearNimComputerTimeout();
      nimGame = createNimGame();
      print("nim: take stones from one row. Last stone loses.");
      printNimHelp();
      printNimBoard();
      if (args[0]) {
        if (!chooseNimStarter(args[0])) printNimStarterHelp();
        return;
      }
      printNimStarterHelp();
    };

    const handleNimInput = (name, args) => {
      if (!nimGame) return;
      if (name === "help") {
        printNimHelp();
        return;
      }
      if (name === "restart") {
        clearNimComputerTimeout();
        nimGame = createNimGame();
        print("nim restarted.");
        printNimHelp();
        printNimBoard();
        printNimStarterHelp();
        return;
      }
      if (name === "quit") {
        leaveNim("left nim.");
        return;
      }
      if (nimGame.state === NIM_STATES.SELECTING_STARTER) {
        if (!chooseNimStarter(name)) {
          printNimStarterHelp();
        }
        return;
      }
      if (nimGame.state === NIM_STATES.PC_THINKING) {
        print("wait for pc.");
        return;
      }

      const values = [name, ...args];
      if (
        values.length !== 2 ||
        !values.every((value) => /^\d+$/.test(value))
      ) {
        print("nim: enter a move as <heap> <count>, e.g. 1 2. Type help.");
        return;
      }

      const heap = Number(values[0]);
      const count = Number(values[1]);
      const current = nimGame.heaps[heap - 1];
      if (heap < 1 || heap > nimGame.heaps.length) {
        print(`nim: heap must be between 1 and ${nimGame.heaps.length}.`);
        return;
      }
      if (current === 0) {
        print(`nim: heap ${heap} is empty.`);
        return;
      }
      if (count < 1 || count > current) {
        print(`nim: take between 1 and ${current} from heap ${heap}.`);
        return;
      }

      const playerMove = {
        heap,
        count,
        next: nimGame.heaps.map((value, index) =>
          index === heap - 1 ? value - count : value,
        ),
      };
      nimGame.heaps = playerMove.next;
      print(`you take ${playerMove.count} from heap ${playerMove.heap}.`);
      if (nimTotal(nimGame.heaps) === 0) {
        finishNim("pc wins.", "text-rose-400");
        return;
      }

      scheduleNimComputerTurn();
    };

    const commands = {
      help() {
        print("available commands:", "text-emerald-400");
        const rows = [
          ["help", "show this message"],
          ["ls [path]", "list entries in a directory"],
          ["cd <dir>", "change directory (use .. or / or ~)"],
          ["pwd", "print working directory"],
          ["open <slug>", "open an entry in a new tab"],
          ["nim", "play Nim against the computer"],
          ["whoami", "you tell me"],
          ["clear", "clear the screen"],
          ["exit", "leave the terminal"],
        ];
        for (const [name, desc] of rows) {
          printHTML(
            `  <span class="text-emerald-300">${escapeHTML(name.padEnd(18))}</span><span class="text-zinc-400">${escapeHTML(desc)}</span>`,
          );
        }
      },

      pwd() {
        print(cwd);
      },

      whoami() {
        print("visitor");
      },

      clear() {
        output.replaceChildren();
      },

      exit() {
        clearNimComputerTimeout();
        try {
          window.localStorage.setItem(STORAGE_KEY, "human");
        } catch {
          /* storage unavailable */
        }
        window.location.assign("/");
      },

      ls(args) {
        const target = resolvePath(args[0] ?? cwd);
        const listing = listAt(target);
        if (!listing) {
          print(`ls: cannot access '${args[0] ?? target}': no such directory`);
          return;
        }
        if (listing.length === 0) {
          print("(empty)", "text-zinc-500");
          return;
        }
        for (const item of listing) {
          if (item.kind === "dir") {
            printHTML(
              `<span class="text-emerald-300">${escapeHTML(item.name)}/</span>`,
            );
          } else {
            printHTML(
              `<span class="text-emerald-100">${escapeHTML(item.name)}</span>  <span class="text-zinc-500">${escapeHTML(item.title)}</span>`,
            );
          }
        }
      },

      cd(args) {
        const target = resolvePath(args[0] ?? "/");
        if (target === "/") {
          cwd = "/";
          return;
        }
        const segments = target.split("/").filter(Boolean);
        if (segments.length === 1 && collections.includes(segments[0])) {
          cwd = target;
          return;
        }
        print(`cd: no such directory: ${args[0] ?? target}`);
      },

      open(args) {
        if (!args[0]) {
          print("open: missing argument. usage: open <slug>");
          return;
        }
        const resolved = resolvePath(args[0]);
        const segments = resolved.split("/").filter(Boolean);
        let collection;
        let slug;
        if (segments.length === 2 && collections.includes(segments[0])) {
          [collection, slug] = segments;
        } else if (segments.length === 1) {
          const here = cwd.split("/").filter(Boolean);
          if (here.length === 1 && collections.includes(here[0])) {
            collection = here[0];
            slug = segments[0];
          } else {
            print(
              "open: ambiguous. cd into projects/, writing/, or reviews/ first, or use open <collection>/<slug>.",
            );
            return;
          }
        } else {
          print(`open: not an entry: ${args[0]}`);
          return;
        }
        const entry = findEntry(collection, slug);
        if (!entry) {
          print(`open: not found: ${slug}`);
          return;
        }
        const url = `/${collection}/${slug}/`;
        printHTML(
          `opening <span class="text-emerald-300">${escapeHTML(url)}</span> in a new tab...`,
        );
        window.open(url, "_blank", "noopener,noreferrer");
      },

      nim(args) {
        startNim(args);
      },
    };

    commands.gui = commands.exit;

    const completionsAt = (path) => {
      const listing = listAt(path);
      if (!listing) return [];
      return listing.map((item) =>
        item.kind === "dir" ? `${item.name}/` : item.name,
      );
    };

    const commonPrefix = (values) => {
      if (values.length === 0) return "";
      let prefix = values[0];
      for (const value of values.slice(1)) {
        while (prefix && !value.startsWith(prefix)) {
          prefix = prefix.slice(0, -1);
        }
        if (!prefix) return "";
      }
      return prefix;
    };

    const handleTab = () => {
      if (nimGame) return;
      const value = input.value;
      const parts = value.split(/\s+/);
      if (parts.length < 2) return;
      const fragment = parts[parts.length - 1];
      const lastSlash = fragment.lastIndexOf("/");
      const dir =
        lastSlash === -1
          ? cwd
          : resolvePath(fragment.slice(0, lastSlash + 1) || "/");
      const prefixFragment =
        lastSlash === -1 ? fragment : fragment.slice(lastSlash + 1);
      const dirPart = lastSlash === -1 ? "" : fragment.slice(0, lastSlash + 1);
      const candidates = completionsAt(dir).filter((name) =>
        name.toLowerCase().startsWith(prefixFragment.toLowerCase()),
      );
      if (candidates.length === 0) return;
      if (candidates.length === 1) {
        parts[parts.length - 1] = dirPart + candidates[0];
        input.value = parts.join(" ");
        renderInput();
        return;
      }
      // Multiple matches: extend to the longest common prefix (bash behavior),
      // and only list when there is nothing further to fill in.
      const shared = commonPrefix(candidates);
      if (shared.length > prefixFragment.length) {
        parts[parts.length - 1] = dirPart + shared;
        input.value = parts.join(" ");
        renderInput();
        return;
      }
      print(candidates.join("  "), "text-zinc-500");
      scrollToBottom();
    };

    const run = (raw) => {
      const trimmed = raw.trim();
      printHTML(
        `<span class="text-emerald-400">${escapeHTML(promptLabel())}</span> ${escapeHTML(raw)}`,
      );
      if (!trimmed) {
        if (isSelectingNimStarter()) {
          chooseNimStarter(nimGame.starterSelection);
        }
        return;
      }
      const [name, ...args] = trimmed.split(/\s+/);
      if (nimGame) {
        if (name === "exit") {
          clearNimComputerTimeout();
          commands.exit(args);
          return;
        }
        if (name === "clear") {
          commands.clear();
          printNimBoard();
          if (isSelectingNimStarter()) printNimStarterHelp();
          return;
        }
        handleNimInput(name, args);
        return;
      }
      const cmd = commands[name];
      if (!cmd) {
        print(`${name}: command not found. type 'help'.`);
        return;
      }
      cmd(args);
    };

    form.addEventListener("submit", (event) => {
      event.preventDefault();
      const value = input.value;
      input.value = "";
      renderInput();
      run(value);
      if (value.trim()) {
        history.push(value);
        historyIndex = history.length;
      }
      renderPrefix();
      scrollToBottom();
    });

    input.addEventListener("input", renderInput);

    input.addEventListener("keydown", (event) => {
      if (event.key === "Tab") {
        event.preventDefault();
        handleTab();
        return;
      }
      if (event.key === "ArrowUp") {
        if (toggleNimStarterSelection()) {
          event.preventDefault();
          return;
        }
        if (history.length === 0) return;
        event.preventDefault();
        if (historyIndex === history.length) draft = input.value;
        historyIndex = Math.max(0, historyIndex - 1);
        input.value = history[historyIndex];
        renderInput();
        return;
      }
      if (event.key === "ArrowDown") {
        if (toggleNimStarterSelection()) {
          event.preventDefault();
          return;
        }
        if (history.length === 0) return;
        event.preventDefault();
        historyIndex = Math.min(history.length, historyIndex + 1);
        input.value =
          historyIndex === history.length ? draft : history[historyIndex];
        renderInput();
        return;
      }
      if (event.key === "l" && event.ctrlKey) {
        event.preventDefault();
        commands.clear();
        if (nimGame) printNimBoard();
        if (isSelectingNimStarter()) printNimStarterHelp();
      }
    });

    document.addEventListener("click", (event) => {
      const target = event.target;
      if (
        target instanceof HTMLAnchorElement ||
        window.getSelection()?.toString()
      )
        return;
      input.focus();
    });

    // Blink the cursor from JS: a CSS animation would be suppressed by the
    // global reduced-motion rule, but the cursor blink is a wanted affordance.
    let cursorVisible = true;
    setInterval(() => {
      cursorVisible = !cursorVisible;
      shadow.style.setProperty(
        "--term-cursor-opacity",
        cursorVisible ? "1" : "0",
      );
    }, 530);

    renderPrefix();
    banner();
    renderInput();
    input.focus();
  </script>
</TerminalLayout>
