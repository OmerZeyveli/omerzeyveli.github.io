---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About" description="About Riive">
  <section class="mx-auto max-w-3xl space-y-6">
    <p class="text-sm uppercase tracking-[0.2em] text-zinc-400">About</p>
    <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">About</h1>
    <p class="leading-7 text-zinc-300">
      Hi, I'm Ömer (Riive) Zeyveli! I'm a computer engineer with a passion for
      science and gaming. In my free time, I like to work on personal projects,
      contribute to open source, and learn new skills. I'm always looking for
      new opportunities to collaborate and create amazing things together with
      others!
    </p>
  </section>
</BaseLayout>
