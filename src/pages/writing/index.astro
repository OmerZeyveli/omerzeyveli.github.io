---
// Purpose: Render the writing listing page.
// Scope: Route-level listing for writing.
// Audience: Site visitors.
import BaseLayout from "../../layouts/BaseLayout.astro";
import WritingCard from "../../components/ui/WritingCard.astro";
import { getWritingPosts } from "../../lib/content";

const posts = await getWritingPosts();
---

<BaseLayout
  title="Writing"
  description="Essays, devlogs, notes, and breakdowns."
>
  <section class="space-y-6 sm:space-y-8">
    <div class="space-y-2">
      <p class="text-sm uppercase tracking-[0.2em] text-zinc-400">Writing</p>
      <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">Writing</h1>
      <p class="max-w-2xl text-zinc-400">
        Essays, development notes, process logs, and technical breakdowns.
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-2">
      {
        posts.map((post) => (
          <WritingCard
            href={`/writing/${post.id}/`}
            cover={post.data.cover}
            coverAlt={post.data.coverAlt}
            title={post.data.title}
            description={post.data.description}
            category={post.data.category}
            pubDate={post.data.pubDate}
          />
        ))
      }
    </div>
  </section>
</BaseLayout>
