---
// Purpose: Render a project detail page.
// Scope: Route-level detail template for projects.
// Audience: Site visitors.
import { getCollection, render } from "astro:content";
import PostLayout from "../../layouts/PostLayout.astro";
import Figure from "../../components/content/Figure.astro";
import YouTubeEmbed from "../../components/content/YouTubeEmbed.astro";

export async function getStaticPaths() {
  const projects = await getCollection(
    "projects",
    ({ data }) => !data.archived,
  );

  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const { year, status, category, stack, repoUrl, liveUrl } = project.data;
---

<PostLayout
  title={project.data.title}
  description={project.data.summary}
  pubDate={project.data.pubDate}
  cover={project.data.cover}
  coverAlt={project.data.coverAlt}
>
  <div slot="meta" class="flex flex-wrap items-center gap-2 text-sm sm:gap-3">
    <span class="rounded-full border border-zinc-700 px-3 py-1 text-zinc-300">
      {category}
    </span>
    <span class="rounded-full border border-zinc-700 px-3 py-1 text-zinc-300">
      {year}
    </span>
    <span class="rounded-full border border-zinc-700 px-3 py-1 text-zinc-300">
      {status}
    </span>
    {
      stack.map((item) => (
        <span class="rounded-full border border-zinc-800 px-3 py-1 text-zinc-400">
          {item}
        </span>
      ))
    }
    {
      repoUrl && (
        <a
          href={repoUrl}
          class="rounded-full border border-zinc-700 px-3 py-1 text-zinc-300 transition-colors hover:bg-zinc-800"
          target="_blank"
          rel="noopener noreferrer"
        >
          Repository ↗
        </a>
      )
    }
    {
      liveUrl && (
        <a
          href={liveUrl}
          class="rounded-full border border-zinc-700 px-3 py-1 text-zinc-300 transition-colors hover:bg-zinc-800"
          target="_blank"
          rel="noopener noreferrer"
        >
          Live Site ↗
        </a>
      )
    }
  </div>

  <Content components={{ Figure, YouTubeEmbed }} />
</PostLayout>
