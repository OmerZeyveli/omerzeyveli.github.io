---
// Purpose: Render the projects listing page.
// Scope: Route-level listing for projects.
// Audience: Site visitors.
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectCard from "../../components/ui/ProjectCard.astro";
import { getProjects } from "../../lib/content";

const projects = await getProjects();
---

<BaseLayout
  title="Projects"
  description="Project case studies and experiments."
>
  <section class="space-y-6 sm:space-y-8">
    <div class="space-y-2">
      <p class="text-sm uppercase tracking-[0.2em] text-zinc-400">Projects</p>
      <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">
        Projects
      </h1>
      <p class="max-w-2xl text-zinc-400">
        Product work, experiments, tools, and developer-focused case studies.
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-2">
      {
        projects.map((project) => (
          <ProjectCard
            href={`/projects/${project.id}/`}
            cover={project.data.cover}
            coverAlt={project.data.coverAlt}
            title={project.data.title}
            summary={project.data.summary}
            category={project.data.category}
            year={project.data.year}
            stack={project.data.stack}
          />
        ))
      }
    </div>
  </section>
</BaseLayout>
