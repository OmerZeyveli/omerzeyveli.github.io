---
import { getCollection, render } from "astro:content";
import PostLayout from "../../layouts/PostLayout.astro";
import Figure from "../../components/content/Figure.astro";
import YouTubeEmbed from "../../components/content/YouTubeEmbed.astro";

export async function getStaticPaths() {
  const reviews = await getCollection("reviews");

  return reviews.map((review) => ({
    params: { slug: review.id },
    props: { review },
  }));
}

const { review } = Astro.props;
const { Content } = await render(review);
const { type, score } = review.data;
---

<PostLayout
  title={review.data.title}
  description={review.data.description}
  pubDate={review.data.pubDate}
  cover={review.data.cover}
  coverAlt={review.data.coverAlt}
>
  <div slot="meta" class="flex flex-wrap items-center gap-3 text-sm">
    <span class="rounded-full border border-zinc-700 px-3 py-1 text-zinc-300">
      {type}
    </span>
    {
      score != null && (
        <span class="rounded-full border border-zinc-700 px-3 py-1 text-zinc-300">
          {score}/10
        </span>
      )
    }
  </div>

  <Content components={{ Figure, YouTubeEmbed }} />
</PostLayout>
