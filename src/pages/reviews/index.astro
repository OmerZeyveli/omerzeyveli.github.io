---
// Purpose: Render the reviews listing page.
// Scope: Route-level listing for reviews.
// Audience: Site visitors.
import BaseLayout from "../../layouts/BaseLayout.astro";
import ReviewCard from "../../components/ui/ReviewCard.astro";
import { getReviews } from "../../lib/content";

const reviews = await getReviews();
---

<BaseLayout
  title="Reviews"
  description="Reviews across games, movies, series, books, and tech."
>
  <section class="space-y-6 sm:space-y-8">
    <div class="space-y-2">
      <p class="text-sm uppercase tracking-[0.2em] text-zinc-400">Reviews</p>
      <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">Reviews</h1>
      <p class="max-w-2xl text-zinc-400">
        Reviews across games, movies, series, books, and tech.
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-2">
      {
        reviews.map((review) => (
          <ReviewCard
            href={`/reviews/${review.id}/`}
            cover={review.data.cover}
            coverAlt={review.data.coverAlt}
            title={review.data.title}
            description={review.data.description}
            type={review.data.type}
            score={review.data.score}
          />
        ))
      }
    </div>
  </section>
</BaseLayout>
