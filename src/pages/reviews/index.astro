---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getReviews } from "../../lib/content";
import { Image } from "astro:assets";

const reviews = await getReviews();
---

<BaseLayout title="Reviews" description="Reviews across games, movies, series, books, and tech.">
  <section class="space-y-8">
    <div class="space-y-2">
      <p class="text-sm uppercase tracking-[0.2em] text-zinc-400">Reviews</p>
      <h1 class="text-4xl font-semibold tracking-tight">Reviews</h1>
      <p class="max-w-2xl text-zinc-400">
        Reviews across games, movies, series, books, and tech.
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-2">
      {reviews.map((review) => (
        <a
          href={`/reviews/${review.id}/`}
          class="overflow-hidden rounded-[1.75rem] border border-zinc-800 transition hover:bg-zinc-900/60"
        >
          <Image
            src={review.data.cover}
            alt={review.data.coverAlt}
            class="aspect-[16/10] w-full object-cover"
            widths={[600, 900, 1200]}
            sizes="(max-width: 768px) 100vw, 50vw"
          />

          <div class="space-y-3 p-5">
            <div class="flex items-center justify-between gap-4 text-sm text-zinc-500">
              <span>{review.data.type}</span>
              {review.data.score && <span>{review.data.score}/10</span>}
            </div>

            <h2 class="text-xl font-medium">{review.data.title}</h2>
            <p class="text-zinc-400">{review.data.description}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>