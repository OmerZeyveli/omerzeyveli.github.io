---
// Purpose: Provide a post layout with metadata and optional cover image.
// Scope: Layout wrapper for writing, projects, and reviews detail pages.
// Audience: Content detail routes.
import BaseLayout from "./BaseLayout.astro";
import { Image } from "astro:assets";
import { formatDate } from "../lib/date";

interface Props {
  title: string;
  description?: string;
  pubDate?: Date;
  updatedDate?: Date;
  cover?: ImageMetadata;
  coverAlt?: string;
  coverTransitionName?: string;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  cover,
  coverAlt,
  coverTransitionName,
} = Astro.props;

const siteUrl = Astro.site ?? new URL(Astro.url.origin);
const ogImage = cover ? new URL(cover.src, siteUrl).href : undefined;
---

<BaseLayout
  title={title}
  description={description}
  image={ogImage}
  imageAlt={coverAlt}
>
  <article data-post-page class="mx-auto max-w-3xl space-y-8 sm:space-y-10">
    <header class="space-y-5 sm:space-y-6">
      <div class="space-y-3">
        <h1
          class="text-3xl font-semibold tracking-tight sm:text-4xl md:text-5xl"
          data-ball-obstacle="text"
        >
          {title}
        </h1>
        {
          description && (
            <p class="max-w-2xl text-lg leading-relaxed text-zinc-400">
              {description}
            </p>
          )
        }
        {
          pubDate && (
            <div class="flex flex-wrap items-center gap-x-3 text-sm text-zinc-500">
              <time datetime={pubDate.toISOString()}>
                {formatDate(pubDate)}
              </time>
              {updatedDate && (
                <span>
                  · Updated{" "}
                  <time datetime={updatedDate.toISOString()}>
                    {formatDate(updatedDate)}
                  </time>
                </span>
              )}
            </div>
          )
        }
      </div>

      {
        cover && coverAlt && (
          <Image
            src={cover}
            alt={coverAlt}
            data-ball-obstacle="platform"
            class="aspect-16/10 w-full rounded-2xl border border-zinc-800 object-cover sm:rounded-4xl"
            style={
              coverTransitionName &&
              `view-transition-name: ${coverTransitionName};`
            }
            widths={[900, 1400, 1800]}
            sizes="(max-width: 768px) 100vw, 768px"
          />
        )
      }
    </header>

    <slot name="meta" />

    <div class="prose prose-invert prose-zinc max-w-none">
      <slot />
    </div>
  </article>
</BaseLayout>

<script>
  import { navigate } from "astro:transitions/client";

  document.addEventListener("keydown", (event) => {
    if (event.key !== "Escape" || event.defaultPrevented) return;
    if (!document.querySelector("[data-post-page]")) return;

    const target = event.target;
    if (
      target instanceof HTMLElement &&
      (target.isContentEditable ||
        /^(input|textarea|select)$/i.test(target.tagName))
    ) {
      return;
    }

    // The client router records its position in history.state.index; a
    // positive index means the previous entry is an in-site page, so going
    // back follows the visitor's actual path (homepage or listing). Read at
    // keypress time — an event-based flag misses the navigation that loads
    // this module. Direct visits fall back to the collection listing.
    const index =
      typeof history.state?.index === "number" ? history.state.index : 0;
    if (index > 0) {
      history.back();
    } else {
      const [collection] = location.pathname.split("/").filter(Boolean);
      navigate(collection ? `/${collection}/` : "/");
    }
  });
</script>
